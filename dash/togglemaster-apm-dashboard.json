{
  "uid": "togglemaster-apm",
  "title": "ToggleMaster - Service Map",
  "tags": ["togglemaster", "apm", "service-map", "tempo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "row",
      "title": "🗺 Service Map",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "nodeGraph",
      "title": "Mapa de dependências dos serviços",
      "description": "Gerado pelo Tempo metrics_generator (processors: service-graphs + span-metrics). Nós = serviços, arestas = chamadas HTTP/async. Cor indica taxa de erro; tamanho indica volume de requisições. Topologia esperada: evaluation-service → flag-service/targeting-service → auth-service; evaluation-service → SQS → analytics-service.",
      "gridPos": { "x": 0, "y": 1, "w": 16, "h": 14 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "serviceMap",
          "serviceMapQuery": "",
          "serviceMapIncludeNamespace": false
        }
      ],
      "options": {
        "nodes": {
          "mainStatUnit": "req/s",
          "secondaryStatUnit": "percentunit",
          "arcs": [
            { "field": "arc__success", "color": "green" },
            { "field": "arc__error",   "color": "red" }
          ]
        },
        "edges": {
          "mainStatUnit": "req/s"
        }
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Volume de requisições por dependência",
      "description": "Ranking das chamadas entre serviços, gerado pela métrica traces_service_graph_request_total (Tempo metrics generator).",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "sortBy": [{ "displayName": "req/s", "desc": true }]
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "client" },
            "properties": [{ "id": "displayName", "value": "Cliente" }]
          },
          {
            "matcher": { "id": "byName", "options": "server" },
            "properties": [{ "id": "displayName", "value": "Servidor" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "req/s" }]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sort_desc(sum by (client, server) (rate(traces_service_graph_request_total[5m])))",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "client": 0, "server": 1, "Value": 2 }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "📊 RED por serviço  (Rate · Errors · Duration)",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Taxa de requisições — req/s",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity" }
        }
      },
      "targets": [
        {
          "refId": "auth",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"auth-service\"}[2m]))",
          "legendFormat": "auth-service"
        },
        {
          "refId": "flag",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"flag-service\"}[2m]))",
          "legendFormat": "flag-service"
        },
        {
          "refId": "targeting",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"targeting-service\"}[2m]))",
          "legendFormat": "targeting-service"
        },
        {
          "refId": "evaluation",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"evaluation-service\"}[2m]))",
          "legendFormat": "evaluation-service"
        },
        {
          "refId": "analytics",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"analytics-service\"}[2m]))",
          "legendFormat": "analytics-service"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Taxa de erros — % de spans com erro",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "refId": "auth",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"auth-service\",status_code=\"STATUS_CODE_ERROR\"}[2m])) / sum(rate(traces_spanmetrics_calls_total{service_name=\"auth-service\"}[2m]))",
          "legendFormat": "auth-service"
        },
        {
          "refId": "flag",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"flag-service\",status_code=\"STATUS_CODE_ERROR\"}[2m])) / sum(rate(traces_spanmetrics_calls_total{service_name=\"flag-service\"}[2m]))",
          "legendFormat": "flag-service"
        },
        {
          "refId": "targeting",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"targeting-service\",status_code=\"STATUS_CODE_ERROR\"}[2m])) / sum(rate(traces_spanmetrics_calls_total{service_name=\"targeting-service\"}[2m]))",
          "legendFormat": "targeting-service"
        },
        {
          "refId": "evaluation",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"evaluation-service\",status_code=\"STATUS_CODE_ERROR\"}[2m])) / sum(rate(traces_spanmetrics_calls_total{service_name=\"evaluation-service\"}[2m]))",
          "legendFormat": "evaluation-service"
        },
        {
          "refId": "analytics",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"analytics-service\",status_code=\"STATUS_CODE_ERROR\"}[2m])) / sum(rate(traces_spanmetrics_calls_total{service_name=\"analytics-service\"}[2m]))",
          "legendFormat": "analytics-service"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latência p95 por serviço",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity" }
        }
      },
      "targets": [
        {
          "refId": "auth",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(traces_spanmetrics_duration_seconds_bucket{service_name=\"auth-service\"}[2m])) by (le))",
          "legendFormat": "auth-service"
        },
        {
          "refId": "flag",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(traces_spanmetrics_duration_seconds_bucket{service_name=\"flag-service\"}[2m])) by (le))",
          "legendFormat": "flag-service"
        },
        {
          "refId": "targeting",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(traces_spanmetrics_duration_seconds_bucket{service_name=\"targeting-service\"}[2m])) by (le))",
          "legendFormat": "targeting-service"
        },
        {
          "refId": "evaluation",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(traces_spanmetrics_duration_seconds_bucket{service_name=\"evaluation-service\"}[2m])) by (le))",
          "legendFormat": "evaluation-service"
        },
        {
          "refId": "analytics",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(traces_spanmetrics_duration_seconds_bucket{service_name=\"analytics-service\"}[2m])) by (le))",
          "legendFormat": "analytics-service"
        }
      ]
    },
    {
      "type": "row",
      "title": "🔗 Latência e erros entre serviços (service-graphs)",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Taxa de erros entre dependências",
      "description": "Proporção de chamadas com falha entre pares cliente→servidor. Labels gerados pelo processor service-graphs do Tempo.",
      "gridPos": { "x": 0, "y": 25, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity" }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (client, server) (rate(traces_service_graph_request_failed_total[5m])) / sum by (client, server) (rate(traces_service_graph_request_total[5m]))",
          "legendFormat": "{{client}} → {{server}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latência p95 entre dependências",
      "description": "Latência de servidor (server-side) p95 por par cliente→servidor.",
      "gridPos": { "x": 12, "y": 25, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity" }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (client, server, le) (rate(traces_service_graph_request_server_seconds_bucket[5m])))",
          "legendFormat": "{{client}} → {{server}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "🐢 Top operações lentas",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top 20 operações por latência p95",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "sortBy": [{ "displayName": "p95 (s)", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "service_name" },
            "properties": [{ "id": "displayName", "value": "Serviço" }]
          },
          {
            "matcher": { "id": "byName", "options": "span_name" },
            "properties": [{ "id": "displayName", "value": "Operação" }]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [
              { "id": "displayName", "value": "p95 (s)" },
              { "id": "unit", "value": "s" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 0.5  },
                    { "color": "red",    "value": 2    }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "req/s" },
            "properties": [
              { "id": "displayName", "value": "req/s" },
              { "id": "unit",        "value": "reqps" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "errors/s" },
            "properties": [
              { "id": "displayName", "value": "errors/s" },
              { "id": "unit",        "value": "reqps"    }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(20, histogram_quantile(0.95, sum by (service_name, span_name, le) (rate(traces_spanmetrics_duration_seconds_bucket[5m]))))",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        },
        {
          "refId": "rate",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (service_name, span_name) (rate(traces_spanmetrics_calls_total[5m]))",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        },
        {
          "refId": "errors",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (service_name, span_name) (rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m]))",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "Value #p95":   "p95",
              "Value #rate":  "req/s",
              "Value #errors":"errors/s"
            }
          }
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": [
    {
      "title": "Observabilidade OTel",
      "url": "/d/togglemaster-otel",
      "type": "link",
      "icon": "dashboard"
    },
    {
      "title": "Explorar no Tempo",
      "url": "/explore?datasource=tempo",
      "type": "link",
      "icon": "explore"
    }
  ]
}