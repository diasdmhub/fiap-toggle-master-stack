    "panel-2": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "tempo"
                    },
                    "group": "tempo",
                    "kind": "DataQuery",
                    "spec": {
                      "queryType": "serviceMap",
                      "serviceMapIncludeNamespace": false,
                      "serviceMapQuery": "",
                      "serviceMapUseNativeHistograms": false
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Gerado pelo Tempo metrics_generator (processors: service-graphs + span-metrics). Nós = serviços, arestas = chamadas HTTP/async. Cor indica taxa de erro; tamanho indica volume de requisições. Topologia esperada: evaluation-service -> flag-service/targeting-service -> auth-service; evaluation-service -> SQS -> analytics-service.",
        "id": 2,
        "links": [],
        "title": "Mapa de dependências dos serviços",
        "transparent": true,
        "vizConfig": {
          "group": "nodeGraph",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {},
              "overrides": []
            },
            "options": {
              "edges": {
                "mainStatUnit": "req/s"
              },
              "layoutAlgorithm": "layered",
              "nodes": {
                "arcs": [
                  {
                    "color": "#37872D",
                    "field": "arc__success"
                  },
                  {
                    "color": "#C4162A",
                    "field": "arc__error"
                  }
                ],
                "mainStatUnit": "req/s",
                "secondaryStatUnit": "percentunit"
              },
              "zoomMode": "cooperative"
            }
          },
          "version": "13.1.0"
        }
      }
    },
    "panel-3": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "prometheus"
                    },
                    "group": "prometheus",
                    "kind": "DataQuery",
                    "spec": {
                      "editorMode": "code",
                      "expr": "sort_desc(sum by (client, server) (rate(traces_service_graph_request_total[$__rate_interval])))",
                      "format": "table",
                      "instant": true,
                      "legendFormat": ""
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": [
              {
                "group": "organize",
                "kind": "Transformation",
                "spec": {
                  "options": {
                    "excludeByName": {
                      "Time": true
                    },
                    "indexByName": {
                      "Value": 2,
                      "client": 0,
                      "server": 1
                    }
                  }
                }
              }
            ]
          }
        },
        "description": "Ranking das chamadas entre serviços, gerado pela métrica traces_service_graph_request_total (Tempo metrics generator).",
        "id": 3,
        "links": [],
        "title": "Volume de requisições por dependência",
        "vizConfig": {
          "group": "table",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {
                "custom": {
                  "align": "auto",
                  "cellOptions": {
                    "type": "auto"
                  },
                  "footer": {
                    "reducers": []
                  },
                  "inspect": false
                },
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": 0
                    },
                    {
                      "color": "red",
                      "value": 80
                    }
                  ]
                },
                "unit": "reqps"
              },
              "overrides": [
                {
                  "matcher": {
                    "id": "byName",
                    "options": "client"
                  },
                  "properties": [
                    {
                      "id": "displayName",
                      "value": "Cliente"
                    }
                  ]
                },
                {
                  "matcher": {
                    "id": "byName",
                    "options": "server"
                  },
                  "properties": [
                    {
                      "id": "displayName",
                      "value": "Servidor"
                    }
                  ]
                },
                {
                  "matcher": {
                    "id": "byName",
                    "options": "Value"
                  },
                  "properties": [
                    {
                      "id": "displayName",
                      "value": "req/s"
                    }
                  ]
                }
              ]
            },
            "options": {
              "cellHeight": "sm",
              "showHeader": true,
              "sortBy": [
                {
                  "desc": true,
                  "displayName": "req/s"
                }
              ]
            }
          },
          "version": "13.1.0"
        }
      }
    },
