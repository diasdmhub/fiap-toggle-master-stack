          },
          "expr": "sum(rate(http_server_duration_milliseconds_count{job=~\".*targeting-service.*\",http_status_code=~\"5..\"}[2m])) / sum(rate(http_server_duration_milliseconds_count{job=~\".*targeting-service.*\"}[2m]))",
          "legendFormat": "targeting-service"
        },
