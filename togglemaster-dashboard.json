      "id": 7,
      "type": "timeseries",
      "title": "Requisições por segundo — todos os serviços",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 14,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_server_duration_milliseconds_count{job=~\".*auth-service.*\"}[2m]))",
          "legendFormat": "auth-service"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_server_duration_milliseconds_count{job=~\".*flag-service.*\"}[2m]))",
          "legendFormat": "flag-service"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
