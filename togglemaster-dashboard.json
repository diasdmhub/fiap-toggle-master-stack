          "legendFormat": "targeting-service"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_server_duration_milliseconds_count{job=~\".*evaluation-service.*\"}[2m]))",
          "legendFormat": "evaluation-service"
        },
