# ---------- Build ----------
FROM docker.io/library/golang:alpine AS builder
WORKDIR /src

# Copia somente os arquivos necessários - Esta etapa é incluída no cache
COPY ./auth-service/go.mod ./auth-service/handlers.go ./auth-service/key.go ./auth-service/main.go ./
RUN go mod tidy

# Contrução do binário estático
RUN CGO_ENABLED=0 GOOS=linux \
    go build -ldflags='-s -w' -v -o /src/auth.go .


# ---------- Runtime ----------
FROM docker.io/library/alpine:latest
WORKDIR /app

# Copia o binário a partir da imagem "builder"
COPY --from=builder /src/auth.go /app/auth.go

EXPOSE 8001
CMD ["/app/auth.go"]
