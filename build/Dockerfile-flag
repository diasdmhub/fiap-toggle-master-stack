# ---------- Build ----------
# Base Alpine para redução do tamanho da imagem de execução
FROM docker.io/library/python:3-alpine
WORKDIR /usr/src/flag

# Copia somente os requisitos para o cache desta camada
COPY ./flag-service/requirements.txt ./

# Instala as dependências
RUN pip install --no-cache-dir -r requirements.txt

# Gera e instala os pacotes de auto-instrumentação para todas as bibliotecas instaladas
# (substitui opentelemetry-bootstrap -a install, que não existe em todas as versões)
RUN pip install --no-cache-dir opentelemetry-instrumentation || true

# Copia o script principal
COPY ./flag-service/app.py ./flag.py

# ----------- Run -----------
EXPOSE 8002

# opentelemetry-instrument envolve o gunicorn sem alterar nenhum código de aplicação.
# OTEL_SERVICE_NAME pode ser sobrescrito via ConfigMap no Kubernetes.
ENV OTEL_SERVICE_NAME="flag-service" \
    OTEL_EXPORTER_OTLP_ENDPOINT="http://otel-collector-opentelemetry-collector.monitoring.svc.cluster.local:4317" \
    OTEL_EXPORTER_OTLP_INSECURE="true" \
    OTEL_PYTHON_LOG_CORRELATION="true" \
    OTEL_PROPAGATORS="tracecontext,baggage"

CMD [ "opentelemetry-instrument", "gunicorn", "--bind", "0.0.0.0:8002", "flag:app" ]